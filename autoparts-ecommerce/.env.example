# ============================================================
# Autoparts Analytics System v1 — шаблон переменных окружения
# Скопируй в .env и заполни реальными значениями
# НЕ коммить .env в git!
# ============================================================

# --- Ozon Seller API ---
OZON_CLIENT_ID=
OZON_API_KEY=

# --- Wildberries API ---
WB_API_KEY=

# --- ClickHouse ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=autoparts

# --- Пути (переопределяют config/settings.json) ---
# DATA_DIR=data/
# OUTPUT_DIR=data/output/
